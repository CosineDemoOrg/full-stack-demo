# Core
PROJECT_NAME="My App"
ENVIRONMENT="local"
SECRET_KEY="changethis"

# Database
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="app"
POSTGRES_PASSWORD="changethis"
POSTGRES_DB="app"

# Frontend
FRONTEND_HOST="http://localhost:5173"

# CORS (comma separated or JSON list)
BACKEND_CORS_ORIGINS="http://localhost:5173"

# Notifications
# console: logs emails to console (default for local)
# smtp: sends real emails using SMTP settings below
NOTIFICATIONS_PROVIDER="console"

# SMTP config (used when NOTIFICATIONS_PROVIDER=smtp)
SMTP_HOST=""
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL=""
EMAILS_FROM_NAME=""

# Bootstrap user
FIRST_SUPERUSER="admin@example.com"
FIRST_SUPERUSER_PASSWORD="changethis"

# Sentry
SENTRY_DSN=""